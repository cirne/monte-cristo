# Dev-time only. Copy to .env and set your keys (never commit .env).
# Used for LLM-powered indexing, character generation, images, etc.

OPENAI_API_KEY=

# We store images in a DigitalOcean Spaces (S3-compatible) bucket.
# These are only needed for scripts that upload images (migration or generation).
SPACES_ACCESS_KEY_ID=
SPACES_ENDPOINT=https://monte-cristo.sfo3.digitaloceanspaces.com
SPACES_BUCKET=monte-cristo
SPACES_SECRET_ACCESS_KEY=
